# ── Model mode ────────────────────────────────────────────────────────────────
MODEL_MODE=plain          # "plain" or "lora"
MODEL_NAME=Khmer ASR      # Name to display on the Demo

# Used when MODEL_MODE=plain
MODEL_PATH=./checkpoints/wav2vec2-khmer

# Used when MODEL_MODE=lora
BASE_MODEL=facebook/wav2vec2-base
LORA_PATH=./checkpoints/lora-adapter

# ── Processor Backend ─────────────────────────────────────────────────────────
DEVICE=auto                # "cpu", "cuda", or "auto"

# ── Audio ─────────────────────────────────────────────────────────────────────
SAMPLE_RATE=16000
STREAM_BUFFER_SEC=1.0     # how often partials fire (lower = more responsive)
STREAM_OVERLAP_SEC=0.3    # overlap kept between windows

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860
CORS_ORIGINS=["*"]        # lock down in production e.g. ["https://yourdomain.com"]